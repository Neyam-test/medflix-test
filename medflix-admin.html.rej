+var GLOBAL_ABOS = [];
+
+async function showRevenueSplit() {
+   GLOBAL_ABOS = await dbGetAbonnements();
+   
+   // Reset filters
+   document.getElementById('rev-filter-status').value = 'all';
+   document.getElementById('rev-filter-period').value = 'all';
+   document.getElementById('rev-date-start-wrap').style.display = 'none';
+   document.getElementById('rev-date-end-wrap').style.display = 'none';
+   document.getElementById('rev-date-start').value = '';
+   document.getElementById('rev-date-end').value = '';
+
+   document.getElementById('revenue-modal').style.display = 'flex';
+   renderRevenueHistory();
+}
+
+function closeRevenueModal() {
+   document.getElementById('revenue-modal').style.display = 'none';
+}
+
+function renderRevenueHistory() {
+   var statusFilter = document.getElementById('rev-filter-status').value;
+   var periodFilter = document.getElementById('rev-filter-period').value;
+   
+   var dStartWrap = document.getElementById('rev-date-start-wrap');
+   var dEndWrap = document.getElementById('rev-date-end-wrap');
+   
+   if (periodFilter === 'custom') {
+      dStartWrap.style.display = 'block';
+      dEndWrap.style.display = 'block';
+   } else {
+      dStartWrap.style.display = 'none';
+      dEndWrap.style.display = 'none';
+   }
+
+   var cStart = document.getElementById('rev-date-start').value;
+   var cEnd = document.getElementById('rev-date-end').value;
+
+   var revRib = 0;
+   var revBill = 0;
+   var revAutres = 0;
+
+   var now = new Date();
+   var todayStart = new Date(now.getFullYear(), now.getMonth(), now.getDate()).getTime();
+   var day = now.getDay() || 7; 
+   var weekStart = new Date(todayStart - (day - 1) * 86400000).getTime();
+   var monthStart = new Date(now.getFullYear(), now.getMonth(), 1).getTime();
+   var yearStart = new Date(now.getFullYear(), 0, 1).getTime();
+
+   var tHtml = '';
+
+   // Filter and accumulate HTML
+   GLOBAL_ABOS.forEach(function(a) {
+       var tDate = new Date(a.created_at);
+       var tTime = tDate.getTime();
+       
+       if (periodFilter === 'today' && tTime < todayStart) return;
+       if (periodFilter === 'week' && tTime < weekStart) return;
+       if (periodFilter === 'month' && tTime < monthStart) return;
+       if (periodFilter === 'year' && tTime < yearStart) return;
+       if (periodFilter === 'custom') {
+          if (cStart && tTime < new Date(cStart).getTime()) return;
+          if (cEnd && tTime > new Date(cEnd).getTime() + 86400000) return;
+       }
+
+       if (statusFilter !== 'all' && a.statut !== statusFilter) return;
+
+       var montant = parseInt(a.montant) || 199;
+       
+       // Revenue counting conditionally
+       if (a.statut === 'Actif' || a.statut === 'R??sili??') {
+           var m = (a.methode || '').toLowerCase();
+           if (m.includes('rib') || m.includes('virement')) revRib += montant;
+           else if (m.includes('billeterie')) revBill += montant;
+           else revAutres += montant;
+       }
+
+       var stColor = a.statut === 'Actif' ? 'var(--grn)' : (a.statut === 'R??sili??' ? 'var(--red-l)' : 'var(--amb)');
+       var adminName = a.admin || '';
+       if (!adminName || adminName === 'admin@medflix.ma' || adminName === 'admin') adminName = 'Aymane';
+       if (a.statut === 'En attente') adminName = '???';
+       
+       var recuLink = a.recu ? '<a href="'+a.recu+'" target="_blank" style="color:var(--blu);text-decoration:none;font-weight:600;padding:4px 8px;background:rgba(59,130,246,0.1);border-radius:6px;display:inline-block;">Voir le re??u</a>' : '<span style="color:var(--mut);">???</span>';
+
+       tHtml += '<tr style="border-bottom:1px solid var(--line);">' +
+         '<td style="padding:.9rem 1rem;color:var(--mut2);">' + tDate.toLocaleDateString('fr-FR') + ' ' + tDate.toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'}) + '</td>' +
+         '<td style="padding:.9rem 1rem;color:var(--txt);font-weight:500;">' + (a.nom || '') + '<br><span style="font-size:0.8rem;color:var(--mut);">'+a.email+'</span></td>' +
+         '<td style="padding:.9rem 1rem;color:var(--mut);">' + a.semestre + '</td>' +
+         '<td style="padding:.9rem 1rem;"><span style="color:'+stColor+';background:'+stColor.replace('var(','rgba(').replace(')',',0.1)')+';padding:4px 8px;border-radius:6px;font-size:0.8rem;font-weight:600;">' + a.statut + '</span></td>' +
+         '<td style="padding:.9rem 1rem;color:var(--mut);">' + (a.methode || 'N/A') + '</td>' +
+         '<td style="padding:.9rem 1rem;color:var(--mut);">' + adminName + '</td>' +
+         '<td style="padding:.9rem 1rem;">' + recuLink + '</td>' +
+       '</tr>';
+   });
+
+   document.getElementById('rev-rib').textContent = revRib + ' DH';
+   document.getElementById('rev-bill').textContent = revBill + ' DH';
+   document.getElementById('rev-aut').textContent = revAutres + ' DH';
+   document.getElementById('rev-tot').textContent = (revRib + revBill + revAutres) + ' DH';
+
+   if (!tHtml) tHtml = '<tr><td colspan="7" style="padding:2rem;text-align:center;color:var(--mut2);">Aucune transaction trouv??e pour ces filtres.</td></tr>';
