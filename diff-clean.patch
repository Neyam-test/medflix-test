+async function loadRenewalsAdmin() {
+   var sem = document.getElementById('rn-semestre').value;
+   var tbody = document.getElementById('rn-tbody');
+   var actionBox = document.getElementById('rn-action-box');
+   
+   if (!sem) {
+      tbody.innerHTML = '<tr class="empty-row"><td colspan="3">Sв”ңвҢҗlectionnez un semestre в”ңГЎ gauche pour voir les в”ңвҢҗtudiants visв”ңвҢҗs.</td></tr>';
