+      if (u.paidDetails && u.paidDetails.length > 0) {
+          activeSemesters = u.paidDetails.filter(p => getPaidDetailStatus(p) === 'actif').map(p => p.sem);
+      } else if (u.paid && u.paid.length > 0) {
