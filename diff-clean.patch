+async function processBulkRenewal() {
+   var sem = document.getElementById('rn-semestre').value;
+   if (!sem || _renewalsUsersList.length === 0) return;
+   
+   if (!confirm('в”ңГЁtes-vous sв”ңв•—r de vouloir Rв”ңГ«VOQUER l\'abonnement au ' + sem + ' pour ' + _renewalsUsersList.length + ' в”ңвҢҗtudiants et de leur envoyer le mail de fin de saison ?')) return;
+   
+   var btn = document.getElementById('btn-rn-execute');
+   btn.disabled = true;
+   btn.textContent = 'Traitement en cours... Ne fermez pas la page !';
+   
+   var progContainer = document.getElementById('rn-progress-container');
+   var progText = document.getElementById('rn-progress-text');
+   var progBar = document.getElementById('rn-progress-bar');
+   
+   progContainer.style.display = 'block';
+   
+   var total = _renewalsUsersList.length;
+   var done = 0;
+   
+   for (var i = 0; i < total; i++) {
+      var u = _renewalsUsersList[i];
+      
+      // Update DB to revoke access to target sem
+      var newPaid = (u.paid || []).filter(function(s) { return s !== sem; });
+      var newPaidDetails = (u.paidDetails || []).map(function(p) {
+         if (p.sem === sem && getPaidDetailStatus(p) === 'actif') {
+            return Object.assign({}, p, { status: 'resilie', dateResil: getNowLocalISO() });
+         }
+         return p;
+      });
+      
+      await dbUpdateUser(u.email, { paid: newPaid, paidDetails: newPaidDetails });
+      
+      // Send Email
+      var mailBody = "Bonjour " + u.name + ",\n\nVotre abonnement au " + sem + " vient de prendre fin en ce dв”ңвҢҗbut de saison. Le nouveau semestre est d'ores et dв”ңвҢҗjв”ңГЎ disponible sur la plateforme Medflix, n'hв”ңвҢҗsitez pas в”ңГЎ activer votre nouvel accв”ңВҝs depuis votre espace в”ңвҢҗtudiant !\n\nL'в”ңГ«quipe Medflix.";
+      
+      try {
+         await sendEmail('etudiant', u.name, u.email, 'Votre semestre est terminв”ңвҢҗ О“ГҮГ¶ Prв”ңвҢҗparez-vous pour la suite !', mailBody);
+      } catch(e) {
+         console.error('Mail error for ' + u.email, e);
+      }
+      
+      done++;
+      progText.textContent = done + ' / ' + total;
+      progBar.style.width = ((done / total) * 100) + '%';
+      
+      // Delai de pause progressif pour empв”ңВ¬cher un ban temporal cotв”ңвҢҗ EmailJS
+      await new Promise(function(resolve) { setTimeout(resolve, 800); });
+   }
+   
+   btn.style.background = 'var(--grn)';
+   btn.textContent = 'О“ВЈГ  Opв”ңвҢҗration Terminв”ңвҢҗe avec Succв”ңВҝs';
+   alert('Traitement terminв”ңвҢҗ pour ' + done + ' в”ңвҢҗtudiants !');
+   loadRenewalsAdmin(); // re-fetch to clear view
+}
